# Server-only Razorpay Test Mode configuration for the isolated staging project.
# Store real values only in the staging Supabase project's secret manager.
# Do not load this file into Vite, Vercel frontend variables, source control secrets, or production.

RAZORPAY_ENVIRONMENT=test
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_STAGING_TEST_KEY_ID
RAZORPAY_KEY_SECRET=REPLACE_WITH_STAGING_TEST_KEY_SECRET
RAZORPAY_PLAN_ID=plan_REPLACE_WITH_STAGING_TEST_PLAN_ID
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_STAGING_TEST_WEBHOOK_SECRET
SBP_ALLOWED_ORIGINS=https://staging.example.invalid
